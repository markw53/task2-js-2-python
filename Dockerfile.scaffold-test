FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
ENV VIRTUAL_ENV="/opt/venv"

RUN /opt/venv/bin/pip install --upgrade pip && \
    /opt/venv/bin/pip install --no-cache-dir pytest click python-frontmatter

RUN /opt/venv/bin/python -m pytest --version

RUN git config --global user.email "test@test.com" && \
    git config --global user.name "Test"

WORKDIR /target
RUN git init

RUN mkdir -p mdforge && touch mdforge/__init__.py

RUN printf '[build-system]\nrequires = ["setuptools"]\nbuild-backend = "setuptools.build_meta"\n\n[project]\nname = "mdforge"\nversion = "0.0.1"\ndependencies = ["click", "python-frontmatter"]\n\n[tool.setuptools.packages.find]\ninclude = ["mdforge*"]\n' > pyproject.toml

RUN /opt/venv/bin/pip install -e .

RUN mkdir -p /target/tests
COPY behavioral_tests/test_mdforge_behavioral.py /target/tests/test_mdforge_behavioral.py

RUN id user >/dev/null 2>&1 || useradd -m -u 1000 -s /bin/bash user
RUN chown -R user:user /target /opt/venv

USER user
WORKDIR /target

CMD ["bash", "-c", "/opt/venv/bin/python -m pytest /target/tests/test_mdforge_behavioral.py --rootdir=/target/tests -v --tb=short --no-header -rA --color=no -p no:cacheprovider; echo \"Exit code: $?\""]